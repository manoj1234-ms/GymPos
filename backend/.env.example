# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local Docker:
DATABASE_URL=postgresql://gympos:gympos_secure_pass@localhost:5432/gympos_db

# Cloud (e.g. Supabase / Neon / Render):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/gympos_db

# JWT Secret Key (change this to a long random string in production!)
SECRET_KEY=pro-trainer-ultra-secret-2025

# Ollama AI Coach (local LLM)
OLLAMA_HOST=http://localhost:11434

# Email (OTP Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
